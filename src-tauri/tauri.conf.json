{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Temlet",
  "version": "0.3.0",
  "identifier": "com.rumitx.temlet",
  "build": {
    "frontendDist": "../loading",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run fetch:node && npm run fetch:chromium && npm run prepare:sidecar"
  },
  "app": {
    "windows": [
      {
        "title": "Temlet",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/server": "server",
      "resources/seed": "seed",
      "resources/runtime": "runtime",
      "resources/chromium": "chromium"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
