	"item": [
		{
			"name": "Render Items",
			"item": [
				{
					"name": "List Render Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/renders?type=video&topic=animals&sortBy=createdAt&sortOrder=desc&page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders"
							],
							"query": [
								{
									"key": "type",
									"value": "video",
									"description": "Filter by type (optional)"
								},
								{
									"key": "topic",
									"value": "animals",
									"description": "Filter by topic (optional)"
								},
								{
									"key": "status",
									"value": "new",
									"description": "Filter by status (optional)",
									"disabled": true
								},
								{
									"key": "sortBy",
									"value": "createdAt",
									"description": "Field to sort by (optional)"
								},
								{
									"key": "sortOrder",
									"value": "desc",
									"description": "Sort order (asc/desc, optional)"
								},
								{
									"key": "page",
									"value": "1",
									"description": "Page number"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Items per page"
								}
							]
						},
						"description": "Get a paginated list of render items with filtering and sorting options"
					},
					"response": []
				},
				{
					"name": "Create Render Item",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fileName\": \"alligator_1\",\n  \"nexrenderUid\": \"uid123\",\n  \"type\": \"video\",\n  \"topic\": \"animals\",\n  \"channelName\": \"My Channel\",\n  \"channelId\": \"channel_abc\",\n  \"templateAeUrl\": \"https://example.com/template.aep\",\n  \"templateAeComposition\": \"mainComp\",\n  \"autoRender\": true,\n  \"autoCreateMetadata\": false,\n  \"autoUpload\": false,\n  \"uploadScheduleStart\": null,\n  \"uploadFromHour\": null,\n  \"uploadToHour\": null,\n  \"videosPerDay\": 1,\n  \"jsonContent\": {\n    \"template\": \"template1\",\n    \"assets\": []\n  },\n  \"mp4Link\": \"https://example.com/videos/alligator_1.mp4\",\n  \"youtubeMetadata\": null,\n  \"status\": \"new\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/renders",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders"
							]
						},
						"description": "Create a new render item with all available fields"
					},
					"response": []
				},
				{
					"name": "Get Render Item",
