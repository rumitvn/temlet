								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"processing\",\n    \"renderTime\": 120,\n    \"youtubeLink\": \"https://youtube.com/watch?v=test123\",\n    \"youtubeMetadata\": {\n        \"title\": \"Updated title\",\n        \"description\": \"Updated description\",\n        \"tags\": [\"animals\", \"alligator\"]\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/renders/{{renderItemId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders",
								"{{renderItemId}}"
							]
						},
						"description": "Update a render item's fields (partial update supported)"
					},
					"response": []
				},
