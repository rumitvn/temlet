{
	"info": {
		"_postman_id": "nexrender-manager",
		"name": "NexRender Manager",
		"description": "API collection for managing render items and YouTube uploads",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Render Items",
			"item": [
				{
					"name": "List Render Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/renders?type=video&topic=animals&status=new&sortBy=createdAt&sortOrder=desc&page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders"
							],
							"query": [
								{
									"key": "type",
									"value": "video",
									"description": "Filter by type (optional)"
								},
								{
									"key": "topic",
									"value": "animals",
									"description": "Filter by topic (optional)"
								},
								{
									"key": "status",
									"value": "new",
									"description": "Filter by status (optional)"
								},
								{
									"key": "sortBy",
									"value": "createdAt",
									"description": "Field to sort by (optional)"
								},
								{
									"key": "sortOrder",
									"value": "desc",
									"description": "Sort order (asc/desc, optional)"
								},
								{
									"key": "page",
									"value": "1",
									"description": "Page number"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Items per page"
								}
							]
						},
						"description": "Get a paginated list of render items with filtering and sorting options"
					}
				},
				{
					"name": "Create Render Item",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"fileName\": \"alligator_1\",\n    \"type\": \"video\",\n    \"topic\": \"animals\",\n    \"status\": \"new\",\n    \"metadata\": {\n        \"template\": \"template1\",\n        \"assets\": []\n    },\n    \"outputPath\": \"/path/to/output.mp4\",\n    \"youtubeUrl\": null,\n    \"error\": null,\n    \"processingTime\": null,\n    \"tags\": [\"animals\", \"alligator\"],\n    \"description\": \"Video description\",\n    \"title\": \"Video title\",\n    \"thumbnailUrl\": null,\n    \"customFields\": {\n        \"customKey\": \"customValue\"\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/renders",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders"
							]
						},
						"description": "Create a new render item with all available fields"
					}
				},
				{
					"name": "Get Render Item",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/renders/{{renderItemId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders",
								"{{renderItemId}}"
							]
						},
						"description": "Get a single render item by ID with all its fields"
					}
				},
				{
					"name": "Update Render Item",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"processing\",\n    \"processingTime\": 120,\n    \"youtubeUrl\": \"https://youtube.com/watch?v=test123\",\n    \"error\": null,\n    \"tags\": [\"animals\", \"alligator\"],\n    \"description\": \"Updated description\",\n    \"title\": \"Updated title\",\n    \"thumbnailUrl\": \"https://example.com/thumbnail.jpg\",\n    \"customFields\": {\n        \"updatedKey\": \"updatedValue\"\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/renders/{{renderItemId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders",
								"{{renderItemId}}"
							]
						},
						"description": "Update a render item's fields (partial update supported)"
					}
				},
				{
					"name": "Delete Render Item",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/renders/{{renderItemId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders",
								"{{renderItemId}}"
							]
						},
						"description": "Delete a render item"
					}
				},
				{
					"name": "Search Render Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/renders/search?q=alligator&type=video&topic=animals&page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"renders",
								"search"
							],
							"query": [
								{
									"key": "q",
									"value": "alligator",
									"description": "Search query"
								},
								{
									"key": "type",
									"value": "video",
									"description": "Filter by type (optional)"
								},
								{
									"key": "topic",
									"value": "animals",
									"description": "Filter by topic (optional)"
								},
								{
									"key": "page",
									"value": "1",
									"description": "Page number"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Items per page"
								}
							]
						},
						"description": "Search render items by file name with optional type and topic filtering"
					}
				}
			]
		},
		{
			"name": "YouTube Integration",
			"item": [
				{
					"name": "Generate YouTube Metadata",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"json\": {\n        \"template\": \"template1\",\n        \"assets\": [],\n        \"order\": 1\n    },\n    \"title\": \"Video title\",\n    \"description\": \"Video description\",\n    \"tags\": [\"tag1\", \"tag2\"],\n    \"categoryId\": \"27\",\n    \"defaultLanguage\": \"vi\",\n    \"defaultAudioLanguage\": \"vi\",\n    \"scheduleDate\": \"2025-06-08 08:00\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/youtube-metadata",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"youtube-metadata"
							]
						},
						"description": "Generate YouTube metadata (title, description, tags) from render JSON"
					}
				},
				{
					"name": "Upload to YouTube",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "mp4",
									"type": "file",
									"src": "/path/to/video.mp4"
								},
								{
									"key": "title",
									"value": "Test Video Title"
								},
								{
									"key": "description",
									"value": "Test video description"
								},
								{
									"key": "tags",
									"value": "test,video,tags"
								},
								{
									"key": "playlistId",
									"value": ""
								},
								{
									"key": "categoryId",
									"value": "27"
								},
								{
									"key": "defaultLanguage",
									"value": "vi"
								},
								{
									"key": "defaultAudioLanguage",
									"value": "vi"
								},
								{
									"key": "scheduleDate",
									"value": "2025-06-08 08:00"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/youtube-upload",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"youtube-upload"
							]
						},
						"description": "Upload a video to YouTube with metadata"
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "renderItemId",
			"value": "your-render-item-id",
			"type": "string"
		}
	]
}