// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RenderFormat {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model RenderItem {
  id                    String   @id @default(cuid())
  fileName              String   @unique
  nexrenderUid          String
  type                  String   // short or long
  topic                 String   // animal, plant, philosophy, etc.
  channelName           String
  channelId             String
  templateAeUrl         String
  templateAeComposition String
  templateAeRenderFormat Json    // Format with id and name
  templateAeAssets      Json?    // Array of template assets
  renderOutputFolder    String?
  autoRender            Boolean  @default(false)
  autoCreateMetadata    Boolean  @default(false)
  autoUpload            Boolean  @default(false)
  uploadScheduleStart   DateTime?
  uploadFromHour        Int?     // 0-23
  uploadToHour          Int?     // 0-23
  videosPerDay          Int?     @default(1)
  jsonContent           Json
  mp4Link               String
  youtubeMetadata       Json?
  status                String
  renderTime            Int?
  metadataTime          Int?
  uploadTime            Int?
  youtubeLink           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([fileName])
  @@index([status])
  @@index([nexrenderUid])
  @@index([type])
  @@index([topic])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  path      String
  type      String   // builtin or custom
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model OutputFolder {
  id        String   @id @default(cuid())
  name      String
  path      String
  type      String   // builtin or custom
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
} 