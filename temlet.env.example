# Temlet desktop — runtime secrets template
#
# The packaged desktop app reads this file from the OS app-config directory and
# injects each KEY=VALUE into the embedded server's environment. Copy it there
# and fill in the values you need:
#
#   macOS:    ~/Library/Application Support/com.rumitx.temlet/temlet.env
#   Windows:  %APPDATA%\com.rumitx.temlet\temlet.env
#
# DATABASE_URL and WORKING_DIRECTORY are set automatically by the app (to paths
# under its app-data directory); override them here only if you want a custom
# location. Lines starting with '#' and blank lines are ignored.

# --- AI content / image generation ---
OPENAI_API_KEY=
GROK_API_KEY=

# --- Nexrender (After Effects render engine) ---
NEXRENDER_SERVER_URL=http://localhost:3000
NEXRENDER_SECRET=

# --- YouTube upload (Google OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT=
YOUTUBE_TOKEN_JSON=

# --- TikTok upload ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# --- Optional overrides (managed by the app by default) ---
# DATABASE_URL=file:/absolute/path/to/temlet.db
# WORKING_DIRECTORY=/absolute/path/to/assets
